{
  "ConnectionStrings": {
    "Database": "Host=main-db;Port=5432;Database=skilltracker;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Secret": "super-duper-secret-value-that-should-be-in-user-secrets",
    "Issuer": "skilltracker",
    "Audience": "developers",
    "ExpirationInMinutes": 60
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadminpassword",
    "Bucket": "files",
    "UseSsl": false,
    "PubEndpoint": "localhost:9000"
  },
  "Redis": {
    "ConnectionString": "redis:6379,user=redis,password=redis,abortConnect=false",
    "InstanceName": "app"
  },
  "Smtp": {
    "Host": "mailpit",
    "Port": 1025,
    "EnableSsl": false,
    "UseDefaultCredentials": false,
    "Username": "vovan990028@gmail.com",
    "Password": ""
  },
  "Centrifugo": {
    "ApiUrl": "http://centrifugo:8000",
    "ApiKey": "centrifugo-internal-api-key"
  }
}