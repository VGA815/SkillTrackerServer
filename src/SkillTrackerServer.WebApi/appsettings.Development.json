{
  "ConnectionStrings": {
    "Database": "Host=main-db;Port=5432;Database=skilltracker;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "",
    "Audience": "",
    "ExpirationInMinutes": 60
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "files",
    "UseSsl": false,
    "PubEndpoint": ""
  },
  "Redis": {
    "ConnectionString": "",
    "InstanceName": "app"
  },
  "Smtp": {
    "Host": "mailpit",
    "Port": 1025,
    "EnableSsl": false,
    "UseDefaultCredentials": false,
    "Username": "",
    "Password": ""
  },
  "Centrifugo": {
    "ApiUrl": "http://centrifugo:8000",
    "ApiKey": ""
  }
}